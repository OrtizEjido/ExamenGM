generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Identidad ──────────────────────────────────────────────────────────────

// Tabla catálogo de roles. Normaliza el campo `is_admin` del legacy (0/1)
// en un código canónico estable listo para crecer (supervisor, viewer…).
model Role {
  id          Int     @id @default(autoincrement())
  code        String  @unique          // 'admin' | 'normal'
  labelEs     String  @map("label_es")
  users       User[]

  @@map("roles")
}

// Contraseña almacenada como AES-256-CBC cifrado (hex), nunca en texto plano.
// El campo `encryptedPassword` contiene iv:ciphertext separados por ':'.
model User {
  id                Int      @id @default(autoincrement())
  username          String   @unique
  encryptedPassword String   @map("encrypted_password")
  roleId            Int      @map("role_id")
  role              Role     @relation(fields: [roleId], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("users")
}

// ── Inventario ─────────────────────────────────────────────────────────────

model Warehouse {
  id     Int              @id @default(autoincrement())
  name   String
  region String?
  stock  InventoryStock[]

  @@map("warehouses")
}

// PK compuesta (productId + warehouseId) igual que en el legacy.
model InventoryStock {
  productId   Int       @map("product_id")
  warehouseId Int       @map("warehouse_id")
  quantity    Int       @default(0)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@id([productId, warehouseId])
  @@map("inventory_stock")
}

// ── Catálogo de productos (esquema NORMALIZADO; mapeado desde el legacy por el ETL). ──
model Product {
  id          Int              @id @default(autoincrement())
  sku         String?
  name        String?
  description String?
  price       Float?
  category    String?
  supplierId  Int?             @map("supplier_id")
  createdAt   DateTime?        @map("created_at")
  updatedAt   DateTime?        @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  stock       InventoryStock[]

  @@map("products")
}

// ── Devoluciones ───────────────────────────────────────────────────────────

// Tabla catálogo de estatus de devolución.
// Unifica variantes legacy: Approved/aprobada/done → 'approved'/'done'; pending → 'pending'; rejected → 'rejected'.
model RefundStatus {
  code    String   @id  // 'pending' | 'approved' | 'rejected' | 'done'
  labelEs String   @map("label_es")
  refunds Refund[]

  @@map("refund_statuses")
}

// amount: Float (normalizado desde TEXT en el legacy).
// created_at: DateTime (normalizado desde 4 formatos mezclados del legacy).
model Refund {
  id         Int          @id @default(autoincrement())
  saleId     Int?         @map("sale_id")
  userId     Int?         @map("user_id")
  reason     String?
  amount     Float?
  statusCode String       @map("status_code")
  status     RefundStatus @relation(fields: [statusCode], references: [code])
  approvedBy Int?         @map("approved_by")
  createdAt  DateTime?    @map("created_at")

  @@map("refunds")
}

// ── Notificaciones ─────────────────────────────────────────────────────────

// Tabla catálogo de tipos de notificación. Normaliza el campo `kind` (string)
// del legacy en un id estable con etiqueta en español.
model NotificationKind {
  id            Int            @id @default(autoincrement())
  code          String         @unique   // 'info' | 'warn' | 'alert' | 'system' | 'marketing'
  labelEs       String         @map("label_es")
  notifications Notification[]

  @@map("notification_kinds")
}

// El estatus leído/no leído es binario → booleano `read` (SQLite: 0/1).
// `kindId` FK a `notification_kinds`; nullable para tolerar registros legacy sin tipo.
model Notification {
  id        Int               @id @default(autoincrement())
  userId    Int               @map("user_id")
  message   String?
  kindId    Int?              @map("kind_id")
  kind      NotificationKind? @relation(fields: [kindId], references: [id])
  read      Boolean           @default(false)
  createdAt DateTime?         @map("created_at")

  @@map("notifications")
}
