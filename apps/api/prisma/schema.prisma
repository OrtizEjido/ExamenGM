generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Catálogo de productos (esquema NORMALIZADO; mapeado desde el legacy por el ETL).
model Product {
  id          Int       @id @default(autoincrement())
  sku         String?
  name        String?
  description String?
  price       Float?
  category    String?
  supplierId  Int?      @map("supplier_id")
  createdAt   DateTime? @map("created_at")
  updatedAt   DateTime? @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("products")
}

// El estatus leído/no leído es binario → booleano `read` (SQLite lo almacena como 0/1).
model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  message   String?
  kind      String?
  read      Boolean   @default(false)
  createdAt DateTime? @map("created_at")

  @@map("notifications")
}
