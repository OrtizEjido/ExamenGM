# Copiar a `.env` (cp .env.example .env). SQLite local, sin servicios externos.
DATABASE_URL="file:./dev.db"
PORT=4000

# Clave AES-256 para cifrar contraseñas: 64 caracteres hexadecimales (32 bytes).
# En dev se usa la clave por defecto si esta variable no está definida.
# En producción REEMPLAZA este valor con un secreto fuerte.
CIPHER_KEY="4572704d6967726174696f6e44656661756c744b657932303236212121212121"

# Secreto para firmar tokens JWT.
JWT_SECRET="erp-dev-secret-2026"
